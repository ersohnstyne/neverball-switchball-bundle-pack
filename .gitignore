# GITHUB WORKFLOWS
/.github/workflows/*
!/.github/workflows/*.yml

# Autosaves
/data/map-switchball/autosave/*
/data/template-switchball/autosave/*
*.autosave.map

# Tests
data/map-sb*/test.map

# Extensions
*.sol
*.xcf

# Directories
/.vs/*
/.tx/*

# Images that using non-alpha
/gui/*.jpg

# Batch/Shell script files (placed under folder "scripts")
*.bat
*.ps1
*.sh
!scripts/*.sh

# Keep the video files on the local computer
*.mp4

# Backups
*.bak

# Raw text files
/*.txt

# Others
/*.ogg